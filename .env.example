# ─────────────────────────────────────────────────────────────────────────────
# LihokBarangAI — Local Development Environment
# Copy this file: cp .env.example .env and fill in your values.
#
# For production, set these via:
#   supabase secrets set KEY=value
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=

# A random secret string YOU choose — must match what you pass to setWebhook.
# Generate one: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
# Model used: gpt-4o-mini (can override in parsers/openai.ts)
GEMINI_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── SMS Gateway (production only — leave blank for demo) ──────────────────────
# Semaphore (PH): https://semaphore.co
SEMAPHORE_API_KEY=

# ── Pipeline config ───────────────────────────────────────────────────────────
# Controls which ingest channel is active.
# Values: "telegram" | "sms"
# Change this in supabase/functions/ingest/index.ts when switching channels.
CHANNEL=telegram
